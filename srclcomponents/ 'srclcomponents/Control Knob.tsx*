import React, { useRef, useEffect } from "react";
import { Globe, User, Database } from "lucide-react";

interface LaboratoryMonitorProps {
  isPlaying: boolean;
  effectId: string;
  intensity: number;
  audioLevel: number;
}

const SHAPE_POOLS = {
  celestial: ["🪐", "☄️", "🛰️", "🚀", "🛸", "🌍", "☀️", "🌙"],
  biological: ["🐕", "🐈", "🐎", "🦅", "🌿", "🍄", "🧬", "🦠"],
  dance: ["🕺", "💃", "🕴️", "🤸", "👯", "🏃"],
  tech: ["⚙️", "🔋", "📡", "💾", "📟", "🔩"],
};

export default function LaboratoryMonitor({ isPlaying, effectId, intensity, audioLevel }: LaboratoryMonitorProps) {
  const canvasRef = useRef<HTMLCanvasElement | null>(null);

  useEffect(() => {
    const canvas = canvasRef.current;
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    let frame = 0;
    let animationFrameId: number;
    let entities: any[] = [];

    const initEntities = () => {
      const allShapes = [...SHAPE_POOLS.celestial, ...SHAPE_POOLS.biological, ...SHAPE_POOLS.dance, ...SHAPE_POOLS.tech];
      entities = Array.from({ length: 50 }).map(() => ({
        symbol: allShapes[Math.floor(Math.random() * allShapes.length)],
        size: 30 + Math.random() * 40,
        speed: 0.5 + Math.random() * 2,
        orbit: 50 + Math.random() * 400,
        angle: Math.random() * Math.PI * 2,
        depth: Math.random(),
      }));
    };

    const draw = () => {
      frame++;
      ctx.fillStyle = "#020802";
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      ctx.save();
      const color = "#1aff80";
      ctx.shadowBlur = 5 + (audioLevel * 20);
      ctx.shadowColor = color;
      const boost = isPlaying ? 1 + (audioLevel * 1.5) : 0.1;
      const flux = intensity / 100;

      entities.forEach((ent, i) => {
        const orbitSpeed = (ent.speed * 0.01) * (1 + flux) * (0.5 + audioLevel * 5);
        ent.angle += isPlaying ? orbitSpeed : orbitSpeed * 0.1;
        const centerX = canvas.width / 2;
        const centerY = canvas.height / 2;
        const ox = centerX + Math.cos(ent.angle) * ent.orbit * (1.2 - ent.depth);
        const oy = centerY + Math.sin(ent.angle * 0.5) * (ent.orbit * 0.5) * (1.2 - ent.depth);
        const scale = (0.5 + ent.depth) * (1 + (audioLevel * 1.2));
        ctx.globalAlpha = (0.2 + ent.depth * 0.6) * Math.min(1, boost);
        ctx.font = `${ent.size * scale}px sans-serif`;
        ctx.fillStyle = color;
        ctx.fillText(ent.symbol, ox, oy);
      });

      ctx.restore();
      ctx.fillStyle = color;
      ctx.font = "bold 14px monospace";
      ctx.fillText(`VAULT-TEC RECON | MODE: ${effectId.toUpperCase()}`, 40, 50);
      ctx.fillText(`FLUX_LVL: ${(intensity).toFixed(1)}%`, 40, 75);
      ctx.fillText(`SIGNAL_LVL: ${(audioLevel * 100).toFixed(1)}%`, 40, 100);
      animationFrameId = requestAnimationFrame(draw);
    };

    initEntities();
    draw();
    return () => cancelAnimationFrame(animationFrameId);
  }, [isPlaying, effectId, intensity, audioLevel]);

  return (
    <div className="relative w-full aspect-[21/9] bg-[#2a2d1e] rounded-[4rem] border-[18px] border-[#1a1c14] shadow-[0_60px_100px_rgba(0,0,0,0.9),inset_0_4px_20px_rgba(255,255,255,0.05)] overflow-hidden flex flex-col items-center">
        <div className="w-[95%] h-[85%] mt-6 rounded-[2rem] overflow-hidden border-[12px] border-[#1a1c14] bg-[#050f05] relative">
            <canvas ref={canvasRef} className="w-full h-full block" width={1600} height={700} />
            <div className="absolute bottom-6 right-8 flex gap-6 opacity-60 text-[#1aff80]">
                <Globe size={20} />
                <User size={20} />
                <Database size={20} />
            </div>
        </div>
        <div className="w-full h-[15%] flex items-center justify-between px-16 text-[#b4b8a1]/30">
           <span className="text-[10px] font-black tracking-[0.3em]">HOLOGRAPHIC RECONNAISSANCE TERMINAL</span>
           <div className="text-[12px] font-black tracking-[0.6em]">MODEL 3000-X LARGE</div>
        </div>
    </div>
  );
}
