import React, { useState, useRef, useEffect } from "react";
import { Play, Pause, Upload, X, Dices, Settings } from "lucide-react";
import ControlKnob from "./components/ControlKnob";
import Visualizer from "./components/Visualizer";
import LaboratoryMonitor from "./components/LaboratoryMonitor";

const EFFECTS = [
  { id: "clean", name: "Status: OK" },
  { id: "melted", name: "Rad-Melt" },
  { id: "sludge", name: "Toxic Mire" },
  { id: "whoa", name: "V.A.T.S. Link" },
  { id: "ghost", name: "Stealth Boy" },
  { id: "vortex", name: "Dust Storm" },
  { id: "neon", name: "Plasma Flux" },
  { id: "bitcrush", name: "Data Corrupt" },
  { id: "echo", name: "Vault Echo" },
];

export default function App() {
  const [isPlaying, setIsPlaying] = useState(false);
  const [knobValue, setKnobValue] = useState(50);
  const [currentEffectIndex, setCurrentEffectIndex] = useState(0);
  const [trackUrl, setTrackUrl] = useState<string | null>(null);
  const [trackName, setTrackName] = useState<string>("NO HOLOTAPE DETECTED");
  const [audioLevel, setAudioLevel] = useState(0);
  
  const audioRef = useRef<HTMLAudioElement | null>(null);
  const fileInputRef = useRef<HTMLInputElement | null>(null);
  const audioCtxRef = useRef<AudioContext | null>(null);
  const filterNodeRef = useRef<BiquadFilterNode | null>(null);
  const distortionNodeRef = useRef<WaveShaperNode | null>(null);
  const delayGainRef = useRef<GainNode | null>(null);
  const delayNodeRef = useRef<DelayNode | null>(null);

  const currentEffect = EFFECTS[currentEffectIndex];

  useEffect(() => {
    if (!audioRef.current || audioCtxRef.current) return;
    const ctx = new (window.AudioContext || (window as any).webkitAudioContext)();
    audioCtxRef.current = ctx;

    const source = ctx.createMediaElementSource(audioRef.current);
    const analyzer = ctx.createAnalyser();
    analyzer.fftSize = 256;

    const filter = ctx.createBiquadFilter();
    filter.type = "lowpass";
    filter.frequency.value = 20000;

    const distortion = ctx.createWaveShaper();
    const initialCurve = new Float32Array(2);
    initialCurve[0] = -1; initialCurve[1] = 1;
    distortion.curve = initialCurve;

    const delay = ctx.createDelay(2.0);
    const dGain = ctx.createGain(); dGain.gain.value = 0;

    source.connect(filter);
    filter.connect(distortion);
    distortion.connect(analyzer);
    source.connect(delay);
    delay.connect(dGain);
    dGain.connect(analyzer);
    analyzer.connect(ctx.destination);

    filterNodeRef.current = filter;
    distortionNodeRef.current = distortion;
    delayGainRef.current = dGain;
    delayNodeRef.current = delay;

    const dataArray = new Uint8Array(analyzer.frequencyBinCount);
    const analyze = () => {
      analyzer.getByteFrequencyData(dataArray);
      let sum = 0;
      for (let i = 0; i < dataArray.length; i++) sum += dataArray[i];
      setAudioLevel(sum / dataArray.length / 255);
      requestAnimationFrame(analyze);
    };
    analyze();
  }, [trackUrl]);

  useEffect(() => {
    if (!audioCtxRef.current) return;
    const intensity = knobValue / 100;
    const time = audioCtxRef.current.currentTime;

    if (filterNodeRef.current) {
        filterNodeRef.current.type = "lowpass";
        filterNodeRef.current.frequency.setTargetAtTime(20000, time, 0.1);
        filterNodeRef.current.Q.setTargetAtTime(1, time, 0.1);
    }
    if (delayGainRef.current) delayGainRef.current.gain.setTargetAtTime(0, time, 0.1);

    switch (currentEffect.id) {
      case "melted":
      case "sludge":
        const f = 15000 - (intensity * 14800);
        filterNodeRef.current?.frequency.setTargetAtTime(Math.max(200, f), time, 0.1);
        filterNodeRef.current?.Q.setTargetAtTime(intensity * 25, time, 0.1);
        break;
      case "neon":
      case "bitcrush":
        if (distortionNodeRef.current) {
          const k = intensity * 600;
          const n = 44100;
          const c = new Float32Array(n);
          for (let i = 0; i < n; ++i) {
            const x = (i * 2) / n - 1;
            c[i] = ((3 + k) * x * 50 * (Math.PI / 180)) / (Math.PI + k * Math.abs(x));
          }
          distortionNodeRef.current.curve = c;
        }
        break;
      case "echo":
        delayGainRef.current?.gain.setTargetAtTime(intensity * 0.95, time, 0.1);
        delayNodeRef.current?.delayTime.setTargetAtTime(0.1 + intensity * 0.8, time, 0.1);
        break;
    }
  }, [knobValue, currentEffectIndex]);

  const togglePlay = async () => {
    if (!trackUrl || !audioRef.current) return;
    if (audioCtxRef.current?.state === "suspended") await audioCtxRef.current.resume();
    isPlaying ? audioRef.current.pause() : audioRef.current.play();
    setIsPlaying(!isPlaying);
  };

  const handleFileUpload = (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (file) {
      if (trackUrl) URL.revokeObjectURL(trackUrl);
      setTrackUrl(URL.createObjectURL(file));
      setTrackName(file.name.toUpperCase());
      setIsPlaying(false);
    }
  };

  return (
    <div className="min-h-screen w-full flex flex-col items-center bg-[#12120f] text-[#1aff80] font-mono p-8 select-none uppercase tracking-widest overflow-y-auto">
      <div className="w-full max-w-6xl bg-[#3a3d2e] rounded-[4rem] border-[20px] border-[#2a2d1e] flex flex-col overflow-hidden relative shadow-2xl">
        <div className="w-full pt-10 pb-4 flex flex-col items-center border-b-8 border-[#2a2d1e] bg-[#343729]">
          <span className="text-[12px] font-black tracking-[0.6em] text-[#b4b8a1]">VAULT-TEC INDUSTRIES TERMINAL</span>
        </div>

        <div className="flex-1 p-10 flex flex-col gap-10">
          <LaboratoryMonitor isPlaying={isPlaying} effectId={currentEffect.id} intensity={knobValue} audioLevel={audioLevel} />

          <div className="grid grid-cols-1 lg:grid-cols-2 gap-10 bg-[#2a2d1e]/50 p-10 rounded-[3rem] border-4 border-[#1a1c14]">
            <div className="bg-[#1a1c14] p-6 rounded-2xl border border-[#b4b8a1]/10 flex flex-col gap-4">
              <span className="text-sm font-black text-[#1aff80] truncate">{trackName}</span>
              <button onClick={() => fileInputRef.current?.click()} className="py-4 bg-[#2a2d1e] rounded-xl text-[#b4b8a1] flex items-center justify-center gap-2 border border-[#1aff80]/10">
                <Upload size={18} /> LOAD HOLOTAPE
              </button>
            </div>

            <div className="flex flex-col items-center gap-12">
              <div className="scale-90"><ControlKnob value={knobValue} onChange={setKnobValue} /></div>
              <div className="flex items-center gap-12">
                <button onClick={() => { setCurrentEffectIndex(Math.floor(Math.random() * EFFECTS.length)); setKnobValue(Math.random() * 100); }} className="w-24 h-24 rounded-3xl bg-[#3a3d2e] border-b-[10px] border-[#1a1c14] flex flex-col items-center justify-center">
                  <Dices size={40} className="mb-1" />
                  <span className="text-[10px] font-black">LUCK</span>
                </button>
                <button onClick={togglePlay} className={`w-36 h-36 rounded-full border-b-[12px] border-[#1a1c14] flex items-center justify-center ${isPlaying ? 'bg-[#1aff80] text-[#050f05]' : 'bg-[#2a2d1e] text-[#1aff80]'}`}>
                  {isPlaying ? <Pause size={64} fill="currentColor" /> : <Play size={64} fill="currentColor" className="translate-x-2" />}
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
      <input type="file" ref={fileInputRef} onChange={handleFileUpload} accept="audio/*" className="hidden" />
      <audio ref={audioRef} src={trackUrl || ""} crossOrigin="anonymous" onEnded={() => setIsPlaying(false)} />
    </div>
  );
}
