import React, { useState, useRef, useEffect } from "react";

interface ControlKnobProps {
  value: number;
  onChange: (val: number) => void;
  label?: string;
}

export default function ControlKnob({ value, onChange, label = "INTENSITY" }: ControlKnobProps) {
  const [isDragging, setIsDragging] = useState(false);
  const startY = useRef(0);
  const startValue = useRef(0);

  const handleStart = (clientY: number) => {
    setIsDragging(true);
    startY.current = clientY;
    startValue.current = value;
    document.body.style.cursor = 'ns-resize';
  };

  const handleMove = (clientY: number) => {
    if (!isDragging) return;
    const deltaY = startY.current - clientY;
    const newValue = Math.min(100, Math.max(0, startValue.current + deltaY / 2.5));
    onChange(newValue);
  };

  const handleEnd = () => {
    setIsDragging(false);
    document.body.style.cursor = 'default';
  };

  useEffect(() => {
    const onMouseMove = (e: MouseEvent) => handleMove(e.clientY);
    const onMouseUp = () => handleEnd();
    const onTouchMove = (e: TouchEvent) => handleMove(e.touches[0].clientY);
    const onTouchEnd = () => handleEnd();

    if (isDragging) {
      window.addEventListener('mousemove', onMouseMove);
      window.addEventListener('mouseup', onMouseUp);
      window.addEventListener('touchmove', onTouchMove, { passive: false });
      window.addEventListener('touchend', onTouchEnd);
    }
    return () => {
      window.removeEventListener('mousemove', onMouseMove);
      window.removeEventListener('mouseup', onMouseUp);
      window.removeEventListener('touchmove', onTouchMove);
      window.removeEventListener('touchend', onTouchEnd);
    };
  }, [isDragging, onChange]);

  const rotation = (value / 100) * 270 - 135;

  return (
    <div 
      className="relative group cursor-pointer touch-none" 
      onMouseDown={(e) => handleStart(e.clientY)}
      onTouchStart={(e) => handleStart(e.touches[0].clientY)}
    >
      <div 
        className="absolute inset-0 rounded-full blur-[80px] transition-opacity duration-300"
        style={{ 
          backgroundColor: `rgba(26, 255, 128, ${0.05 + value / 300})`,
          opacity: isDragging ? 0.6 : 0.2 
        }}
      />
      <div className="relative w-80 h-80 rounded-full bg-[#1a1c14] p-2 shadow-[0_40px_100px_rgba(0,0,0,0.9),inset_0_2px_10px_rgba(255,255,255,0.05)] border border-[#b4b8a1]/10 flex items-center justify-center">
        <svg className="absolute inset-0 w-full h-full -rotate-90 scale-[1.05]">
          <circle
            cx="160"
            cy="160"
            r="150"
            fill="none"
            stroke="currentColor"
            strokeWidth="3"
            strokeDasharray="942"
            strokeDashoffset={942 - (942 * (value / 100) * 0.75)}
            className="text-[#1aff80]"
            strokeLinecap="round"
            style={{ transform: 'rotate(135deg)', transformOrigin: 'center' }}
          />
        </svg>
        <div 
          className="w-64 h-64 rounded-full bg-gradient-to-b from-[#3a3d2e] to-[#1a1c14] shadow-[0_20px_60px_rgba(0,0,0,1),inset_0_2px_10px_rgba(255,255,255,0.05)] flex items-center justify-center relative transition-transform duration-75 border border-[#b4b8a1]/10"
          style={{ transform: `rotate(${rotation}deg)` }}
        >
          <div className="absolute inset-0 rounded-full bg-[conic-gradient(from_0deg,_rgba(255,255,255,0.05),_transparent,_rgba(255,255,255,0.05))] opacity-30" />
          <div className="absolute top-8 w-5 h-5 rounded-full bg-[#1aff80] shadow-[0_0_25px_#1aff80]" />
          <div className="w-24 h-24 rounded-full bg-[#050f05] border-4 border-[#1a1c14] shadow-inner flex items-center justify-center">
             <div className="text-[12px] font-black text-[#1aff80] tracking-[0.3em] opacity-60">VT-3000</div>
          </div>
        </div>
      </div>
      <div className="absolute -bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center">
         <span className="text-[10px] font-black text-[#1aff80] tracking-widest">{label}</span>
         <span className="text-xs font-black text-[#1aff80]">{Math.round(value)}%</span>
      </div>
    </div>
  );
}
